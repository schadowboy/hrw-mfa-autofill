{
  "manifest_version": 3,
  "name": "HRW MFA Autofill",
  "version": "1.6.8",
  "description": "MFA-Autofill HRW — AES-256 · Zufälligem Salt · Inline-Confirm · Sender-Check",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline';"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://sso.hs-rw.de/*",
    "https://portal.hs-ruhrwest.de/*",
    "https://owa.hs-ruhrwest.de/*",
    "https://campusnet.hs-ruhrwest.de/*",
    "https://dsf.hs-ruhrwest.de/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sso.hs-rw.de/idp/profile/SAML2/Redirect/SSO*",
        "https://portal.hs-ruhrwest.de/site_publishing_helper/login_check/*",
        "https://portal.hs-ruhrwest.de/SitePages/*",
        "https://owa.hs-ruhrwest.de/owa/*",
        "https://campusnet.hs-ruhrwest.de/*",
        "https://dsf.hs-ruhrwest.de/IdentityServer/*"
      ],
      "js": [
        "lib/totp.js",
        "lib/crypto.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HRW MFA Autofill"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}